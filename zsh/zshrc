# ---------------------------------------------------------------- env
export EDITOR="nvim"
export _ZO_DOCTOR=0
export ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
export NVM_DIR="$HOME/.nvm"
export BUN_INSTALL="$HOME/.bun"
export PATH="$HOME/.local/bin:$BUN_INSTALL/bin:$(go env GOPATH 2>/dev/null)/bin:$PATH"
export GPG_TTY=$(tty)
export BAT_THEME="Catppuccin Mocha"
path=("$HOME/bin" $path)

# -------------------------------------------------------------- zinit
if [ ! -d "$ZINIT_HOME" ]; then
    mkdir -p "$(dirname $ZINIT_HOME)"
    git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi
source "${ZINIT_HOME}/zinit.zsh"

zinit light Aloxaf/fzf-tab
zinit snippet OMZL::git.zsh
zinit snippet OMZP::git
zinit light zsh-users/zsh-syntax-highlighting
zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-completions
zinit snippet OMZP::sudo
zinit snippet OMZP::kubectl
zinit snippet OMZP::command-not-found
zinit light zsh-users/zsh-history-substring-search

# ------------------------------------------------------------ history
export HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt INC_APPEND_HISTORY SHARE_HISTORY HIST_IGNORE_ALL_DUPS HIST_REDUCE_BLANKS GLOBDOTS INTERACTIVE_COMMENTS

# --------------------------------------------------------- completion
autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

export LS_COLORS="$(vivid generate snazzy 2>/dev/null)"
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS} ma=0\;33
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath'

# ---------------------------------------------------------------- fzf
source <(fzf --zsh)
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:200 {}'"
export FZF_ALT_C_OPTS="--preview 'eza --tree --color=always --icons {} | head -50'"
export FZF_DEFAULT_OPTS="--height=50% --border=rounded --info=inline --bind=ctrl-/:toggle-preview --color=bg:#1e1e2e,bg+:#313244,fg:#cdd6f4,fg+:#cdd6f4,hl:#f38ba8,hl+:#f38ba8,info:#cba6f7,prompt:#cba6f7,pointer:#f5e0dc,marker:#b4befe,spinner:#f5e0dc,header:#cba6f7,border:#313244"

# ---------------------------------------------------- nvm (lazy load)
if [ -d "$NVM_DIR" ]; then
  nvm_lazy_load() {
    for _f in node npm npx nvm; do
      typeset -f "$_f" >/dev/null 2>&1 && unset -f "$_f"
    done
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    [ $# -gt 0 ] && command "$@"
  }
  node() { nvm_lazy_load node "$@"; }
  npm()  { nvm_lazy_load npm  "$@"; }
  npx()  { nvm_lazy_load npx  "$@"; }
  nvm()  { nvm_lazy_load nvm  "$@"; }
fi

# --------------------------------------------------------- tool hooks
eval "$(zoxide init --cmd cd zsh)"
eval "$(atuin init zsh --disable-up-arrow)"
eval "$(direnv hook zsh)"
. "$HOME/.local/bin/env"
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"
test -e "$HOME/.iterm2_shell_integration.zsh" && source "$HOME/.iterm2_shell_integration.zsh"

# --------------------------------------------------------------- keys
bindkey -e
bindkey '^W' backward-kill-word
bindkey '^[[H' beginning-of-line
bindkey '^[[F' end-of-line
bindkey '^[[1~' beginning-of-line
bindkey '^[[4~' end-of-line
bindkey '^[[1;5D' backward-word
bindkey '^[[1;5C' forward-word
bindkey '^[[3;5~' kill-word
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward
bindkey '^[w' kill-region
bindkey "^C" interrupt
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
bindkey '\eb' backward-word
bindkey '\ef' forward-word

# ------------------------------------------------------------- prompt
eval "$(starship init zsh)"

