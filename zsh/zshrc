alias ccc='claude --continue'

# ---------------------------------------------------------- functions
mkcd() { mkdir -p "$1" && cd "$1"; }

extract() {
  case "$1" in
    *.tar.bz2) tar xjf "$1" ;;
    *.tar.gz)  tar xzf "$1" ;;
    *.tar.xz)  tar xJf "$1" ;;
    *.zip)     unzip "$1" ;;
    *.7z)      7zz x "$1" ;;
    *)         echo "Unknown format: $1" ;;
  esac
}

gi() { curl -sL "https://www.gitignore.io/api/$1"; }

# yazi: cd to selected dir on exit
y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
    yazi "$@" --cwd-file="$tmp"
    IFS= read -r -d '' cwd < "$tmp"
    [ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
    rm -f -- "$tmp"
}

# ------------------------------------------------------ machine-local
# secrets/hosts (ssh aliases etc), not tracked in macfiles
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"

